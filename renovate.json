{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "swc_*"
      ],
      "groupName": "swc"
    },
    {
      "matchSourceUrls": [
        "https://github.com/astral-sh/ruff"
      ],
      "groupName": "ruff"
    }
  ]
}
